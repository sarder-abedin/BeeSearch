# ── Python runtime artifacts ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/

# ── Environment / secrets ─────────────────────────────────────
.env
.env.*

# ── Generated outputs (mounted as a volume at runtime) ────────
outputs/

# ── ChromaDB store (not used in vectorless RAG) ───────────────
chroma_db/

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore

# ── Editor / OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Docker files themselves (no need to copy into image) ──────
Dockerfile
docker-compose*.yml
.dockerignore

# ── Docs / CI (not needed at runtime) ────────────────────────
docs/
*.md
