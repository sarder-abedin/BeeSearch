# ─────────────────────────────────────────────────────────────
#  ResearchBuddy — Environment Configuration
#
#  HOW TO USE:
#    cp .env.example .env
#    Edit .env with your settings
# ─────────────────────────────────────────────────────────────

# ── Local LLM ────────────────────────────────────────────────
# Must match a model pulled with `ollama pull <model>`
#   llama3.2:3b      2 GB   32k ctx   fast, low-RAM
#   llama3.1:8b      5 GB   32k ctx   recommended
#   mistral-nemo:12b 7 GB  128k ctx   long documents (needs 16 GB RAM)
#   phi4:14b         9 GB   16k ctx   highest reasoning quality
OLLAMA_MODEL=llama3.2:3b
NUM_CTX=32768

# ── Ollama server URL ─────────────────────────────────────────
# Manual install: leave as localhost
# Docker: overridden automatically by docker-compose.yml
OLLAMA_BASE_URL=http://localhost:11434

# ── Streamlit UI port ─────────────────────────────────────────
APP_PORT=8501

# ── Academic APIs (all free) ──────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
CROSSREF_BASE_URL=https://api.crossref.org/works
CROSSREF_EMAIL=your@email.com
ARXIV_MAX_RESULTS=10

# ── Hybrid RAG ────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
CHROMA_PERSIST_DIR=./outputs/chroma_db
HYBRID_TOP_K=8

# ── Document chunking ─────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_DOCUMENT_CHUNKS=500
MAX_SEARCH_RESULTS=8

# ── Large document handling ───────────────────────────────────
# PDFs with more pages than this threshold auto-switch from Docling
# (ML models, ~500 MB RAM) to pdfplumber (streaming, low RAM).
# Lower this value on machines with < 8 GB RAM (e.g. 20 or 30).
# Set to 0 to always use Docling regardless of size.
LARGE_DOC_PAGE_THRESHOLD=50

# ── Google Search microservice (optional) ─────────────────────
GOOGLE_SEARCH_SERVICE_URL=http://localhost:8000

# ── Output ────────────────────────────────────────────────────
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO
